#!/usr/bin/env python3
import click
import logging

from finbot.core.logging import configure_logging
from finbot.model import ScopedSession, TransactionMatch

configure_logging("INFO")
logger = logging.getLogger(__name__)


@click.command()
@click.option("--user-account-id", type=int, required=True, help="User account ID")
@click.option("--status", type=str, default=None, help="Filter by match_status (auto, confirmed, rejected)")
def main(user_account_id: int, status: str | None):
    with ScopedSession() as session:
        query = (
            session.query(TransactionMatch)
            .filter(TransactionMatch.user_account_id == user_account_id)
        )
        if status:
            query = query.filter(TransactionMatch.match_status == status)

        matches = query.order_by(TransactionMatch.created_at.desc()).all()

        if not matches:
            click.echo("No matches found.")
            return

        click.echo(f"Found {len(matches)} match(es) for user_account_id={user_account_id}\n")

        for m in matches:
            out = m.outflow_transaction
            inf = m.inflow_transaction
            out_account = out.linked_account.account_name if out.linked_account else "?"
            inf_account = inf.linked_account.account_name if inf.linked_account else "?"

            click.echo(f"Match #{m.id}  confidence={m.match_confidence}  status={m.match_status}")
            click.echo(f"  OUT: {out.transaction_date:%Y-%m-%d}  {out.transaction_type:15s}  "
                        f"{out.amount:>12.2f} {out.currency}  ({out_account}/{out.sub_account_id})")
            click.echo(f"       {out.description[:60]}")
            click.echo(f"   IN: {inf.transaction_date:%Y-%m-%d}  {inf.transaction_type:15s}  "
                        f"{inf.amount:>12.2f} {inf.currency}  ({inf_account}/{inf.sub_account_id})")
            click.echo(f"       {inf.description[:60]}")
            click.echo()


if __name__ == "__main__":
    main()
